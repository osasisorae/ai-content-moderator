# ─── Prysm AI ───
# All LLM calls (including LangChain, CrewAI, LlamaIndex, and embeddings)
# route through the Prysm proxy. No separate OPENAI_API_KEY needed.
# Prysm injects the upstream provider key automatically.
PRYSM_API_KEY=sk-prysm-your-key-here
PRYSM_BASE_URL=https://prysmai.io/api/v1

# ─── Alert Channels (optional — for features 9, 10, 11) ───
PAGERDUTY_ROUTING_KEY=your-pagerduty-integration-key
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
CUSTOM_WEBHOOK_URL=https://webhook.site/your-unique-id
