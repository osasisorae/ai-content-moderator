# ─── Prysm AI ───
PRYSM_API_KEY=sk-prysm-your-key-here
PRYSM_BASE_URL=https://prysmai.io/api/v1

# ─── Upstream LLM Provider ───
# Note: The actual provider key is stored in Prysm's dashboard.
# The SDK routes through the Prysm proxy, which injects the provider key.
# However, LangChain/CrewAI/LlamaIndex frameworks need a direct key for initialization.
OPENAI_API_KEY=sk-your-openai-key

# ─── Alert Channels (for features 9, 10, 11) ───
PAGERDUTY_ROUTING_KEY=your-pagerduty-integration-key
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
CUSTOM_WEBHOOK_URL=https://webhook.site/your-unique-id
